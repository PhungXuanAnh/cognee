###############################################################################
# Cognee .env — Anthropic (Claude) Configuration
#
# Generated by: setup_cognee_anthropic.sh
# Date: 2026-04-03T09:06:02+07:00
# Anthropic Base: http://127.0.0.1:8080
# Model: claude-sonnet-4.6
# Thinking: enabled (budget=1024)
###############################################################################

################################################################################
#  🧠 LLM Settings — Anthropic
################################################################################
STRUCTURED_OUTPUT_FRAMEWORK="instructor"

# Anthropic provider uses the native AnthropicAdapter which calls the
# Anthropic SDK directly (not litellm).
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-sonnet-4.6"
LLM_API_KEY="no-key-needed"

# ANTHROPIC_BASE_URL is picked up by the Anthropic Python SDK to redirect
# API calls. The SDK appends /v1/messages automatically.
ANTHROPIC_BASE_URL="http://127.0.0.1:8080"

# IMPORTANT: Use anthropic_json, NOT anthropic_tools.
# anthropic_tools mode conflicts with thinking (extended thinking + tool use
# cannot be combined in the same request on many Anthropic-compatible APIs).
LLM_INSTRUCTOR_MODE="anthropic_json"

# Anthropic API REQUIRES max_tokens (not set by the adapter by default).
# Optionally enable thinking with a budget for improved reasoning quality.
LLM_ARGS='{"max_tokens": 8192, "thinking": {"type": "enabled", "budget_tokens": 1024}}'

# Silently drop parameters the API doesn't understand
LITELLM_DROP_PARAMS=True

################################################################################
#  📐 Embedding Settings — OpenAI-compatible endpoint
################################################################################
# Anthropic doesn't provide embeddings, so we use an OpenAI-compatible
# endpoint (same proxy, direct OpenAI, or another embedding service).
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="openai/text-embedding-3-small"
EMBEDDING_ENDPOINT="http://127.0.0.1:8080/v1"
EMBEDDING_API_KEY="no-key-needed"
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MAX_TOKENS=8191
EMBEDDING_BATCH_SIZE=36

# litellm fallback for embedding calls
OPENAI_API_BASE="http://127.0.0.1:8080/v1"

################################################################################
#  📂 Database — keep everything local & file-based
################################################################################
DB_PROVIDER="sqlite"
DB_NAME=cognee_db

# Per-project isolation
DATA_ROOT_DIRECTORY="/home/xuananh/repo/cognee/.cognee_data/"
SYSTEM_ROOT_DIRECTORY="/home/xuananh/repo/cognee/.cognee_system/"

################################################################################
#  🔧 Misc
################################################################################
# Skip the startup embedding connection test: some proxies reject single-string
# input (embed_text("test")), but actual cognify/search paths use List[str] fine.
COGNEE_SKIP_CONNECTION_TEST=true
TELEMETRY_DISABLED=1
